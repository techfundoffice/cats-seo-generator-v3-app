# ============================================================
# SEO Generator V3 - Environment Variables
# Copy to .env and fill in your keys, or use Doppler:
#   doppler login && doppler setup && npm run dev:doppler
# ============================================================

# --- Required ---

# Cloudflare (AI image generation, KV storage, Workers)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id

# AI Content Generation (at least one required)
ANTHROPIC_API_KEY=your_anthropic_key

# --- Recommended ---

# Cloudflare Workers AI (image generation; falls back to CLOUDFLARE_API_TOKEN)
CLOUDFLARE_WORKERS_AI_TOKEN=your_workers_ai_token

# Cloudflare Global API Key (zone-level operations like cache purge)
CLOUDFLARE_GLOBAL_API_KEY=your_global_key
CLOUDFLARE_EMAIL=your_cloudflare_email

# Amazon Affiliate
AMAZON_AFFILIATE_TAG=your-tag-20
AMAZON_CREDENTIAL_ID=your_credential_id
AMAZON_API_SECRET=your_api_secret

# --- Optional ---

# OpenRouter (alternative AI provider)
OPENROUTER_API_KEY=your_openrouter_key

# Google (custom search, Search Console)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# DataForSEO (on-page SEO scoring)
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password

# Apify (Amazon product scraping)
APIFY_TOKEN=your_apify_token

# Skills engine (path to .claude/skills directory)
SKILLS_BASE_PATH=

# Server
PORT=3000

# --- Post-publish QC (Gobii + live SEO) ---
# https://docs.gobii.ai/developers/developer-basics
GOBII_API_KEY=
# Optional; default https://gobii.ai/api/v1
GOBII_API_BASE=
# Seconds to wait on POST /tasks/browser-use/ (max 1350)
GOBII_TASK_WAIT_SECONDS=120
# Ms delay after URL verify before Gobii
POST_PUBLISH_QC_DELAY_MS=4000
# If true (default), missing GOBII_API_KEY fails the pipeline after deploy
POST_PUBLISH_QC_STRICT=true
# Fail live SEO if below this (0 = off)
LIVE_SEO_MIN_SCORE=0
# If true, non-empty Gobii errors[] fails the pipeline
FAIL_ON_GOBII_QC_ERRORS=false
